{
  "name": "vike-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vike dev",
    "build": "bun --bun vike build",
    "preview": "bun --bun vike build && bun --bun vike preview",
    "lint": "bun --bun oxlint .",
    "lint:type-aware": "bun --bun oxlint --type-aware .",
    "format": "bun --bun oxfmt",
    "format:check": "bun --bun oxfmt --check"
  },
  "dependencies": {
    "lucide-solid": "^1.16.0",
    "solid-js": "^1.9.13",
    "tailwind-variants": "^3.2.2",
    "vike": "0.4.257",
    "vike-solid": "^0.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.20.0",
    "solid-devtools": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-solid": "^2.11.12"
  }
